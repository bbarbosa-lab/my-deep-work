APP_NAME=My Deep Work
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
CSRF_SECRET=change-me-another-long-random-string

SESSION_COOKIE_NAME=mdw_session
SESSION_TTL_SECONDS=86400

DATABASE_URL=postgresql://mdw:mdw_secret_change_me@db:5432/mydeepwork
POSTGRES_USER=mdw
POSTGRES_PASSWORD=mdw_secret_change_me
POSTGRES_DB=mydeepwork

REDIS_URL=redis://redis:6379/0

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_HTTPONLY=true
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

RATE_LIMIT_LOGIN_IP=10
RATE_LIMIT_LOGIN_ACCOUNT=5
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15

PASSWORD_RESET_TTL_SECONDS=3600
